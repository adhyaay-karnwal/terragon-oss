# =============================================================================
# TERRAGON PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.production and fill in all values.
# Values marked [REQUIRED] must be set. Values marked [OPTIONAL] can be left empty.
# =============================================================================

# === DATABASE ===
# [AUTO-CONFIGURED] When using docker-compose, this is automatically set.
# Only change if using an external database (e.g., Neon, Supabase).
DATABASE_URL=postgresql://terragon:changeme@postgres:5432/terragon

# === REDIS ===
# [AUTO-CONFIGURED] When using docker-compose with local Redis.
# For external Redis (Upstash), set the URL and token.
REDIS_URL=http://redis:6379
REDIS_TOKEN=

# If using Upstash (optional alternative to local Redis):
# UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# === AUTHENTICATION ===
# [REQUIRED] Your domain with https://
BETTER_AUTH_URL=https://yourdomain.com

# [REQUIRED] Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# [REQUIRED] Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=

# [REQUIRED] Generate with: openssl rand -hex 32
# Must match the INTERNAL_SHARED_SECRET in your PartyKit .env
INTERNAL_SHARED_SECRET=

# [REQUIRED] Generate with: openssl rand -hex 32
# Used to authenticate cron job requests
CRON_SECRET=

# === PUBLIC URLs ===
# [REQUIRED] Your main app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# [REQUIRED] Your PartyKit deployment host (just the hostname, no protocol)
# Example: broadcast.yourname.partykit.dev
NEXT_PUBLIC_BROADCAST_HOST=

# [REQUIRED] Your PartyKit deployment URL (with wss:// protocol)
# Example: wss://broadcast.yourname.partykit.dev
NEXT_PUBLIC_BROADCAST_URL=

# [OPTIONAL] URL to your docs site if deployed separately
NEXT_PUBLIC_DOCS_URL=https://docs.yourdomain.com

# [REQUIRED] Your GitHub App slug (the URL-friendly name)
# Found in your GitHub App URL: github.com/apps/YOUR-APP-SLUG
NEXT_PUBLIC_GITHUB_APP_NAME=

# === AI PROVIDERS ===
# [REQUIRED] Anthropic Claude API key
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# [OPTIONAL] OpenAI API key (used for commit message generation)
# Get from: https://platform.openai.com
OPENAI_API_KEY=

# [OPTIONAL] OpenRouter API key (alternative AI provider)
# Get from: https://openrouter.ai
OPENROUTER_API_KEY=

# [REQUIRED] E2B API key (for sandbox environments)
# Get from: https://e2b.dev
E2B_API_KEY=

# [OPTIONAL] Daytona API key (alternative sandbox provider)
DAYTONA_API_KEY=

# === FILE STORAGE (Cloudflare R2) ===
# [REQUIRED] All R2 settings are required for file uploads
# Get from: Cloudflare Dashboard > R2 > Manage R2 API Tokens

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=

# Name of your public bucket (must exist)
R2_BUCKET_NAME=terragon-public

# Name of your private bucket (must exist)
R2_PRIVATE_BUCKET_NAME=terragon-private

# Public URL for your public bucket
# Get from: R2 bucket > Settings > Public access
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# === GITHUB APP ===
# [REQUIRED] All GitHub App settings are required for authentication
# Create at: https://github.com/settings/apps

# Client ID (starts with Iv1.)
GITHUB_CLIENT_ID=

# Client Secret (generate in app settings)
GITHUB_CLIENT_SECRET=

# Webhook Secret (you set this when creating the app)
GITHUB_WEBHOOK_SECRET=

# App ID (number shown in app settings)
GITHUB_APP_ID=

# Private Key (convert .pem to single line with \n for newlines)
# Convert with: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' your-app.pem
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# === EMAIL (Optional) ===
# [OPTIONAL] Resend API key for transactional emails
# Get from: https://resend.com
RESEND_API_KEY=

# === PAYMENTS (Optional) ===
# [OPTIONAL] Stripe keys for billing features
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CORE_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_CREDIT_PACK=

# === MONITORING (Optional) ===
# [OPTIONAL] Slack webhook for feedback notifications
SLACK_FEEDBACK_WEBHOOK_URL=

# [OPTIONAL] PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === POSTGRES PASSWORD ===
# [REQUIRED] Password for the PostgreSQL database (used by docker-compose)
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=changeme
